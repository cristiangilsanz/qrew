  "components": {
    "schemas": {
      "EntryStatsResponse": {
        "properties": {
          "event_id": {
            "type": "string",
            "format": "uuid",
            "title": "Event Id"
          },
          "since": {
            "type": "string",
            "format": "date-time",
            "title": "Since"
          },
          "total_issued": {
            "type": "integer",
            "title": "Total Issued"
          },
          "total_entered": {
            "type": "integer",
            "title": "Total Entered"
          },
          "total_remaining": {
            "type": "integer",
            "title": "Total Remaining"
          },
          "rejections_by_reason": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Rejections By Reason"
          },
          "last_scan_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Scan At"
          }
        },
        "type": "object",
        "required": [
          "event_id",
          "since",
          "total_issued",
          "total_entered",
          "total_remaining",
          "rejections_by_reason",
          "last_scan_at"
        ],
        "title": "EntryStatsResponse"
      },
      "EntryValidateRequest": {
        "properties": {
          "ticket_jwt": {
            "type": "string",
            "minLength": 1,
            "title": "Ticket Jwt"
          }
        },
        "type": "object",
        "required": [
          "ticket_jwt"
        ],
        "title": "EntryValidateRequest"
      },
      "EntryValidateResponse": {
        "properties": {
          "allowed": {
            "type": "boolean",
            "title": "Allowed"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          },
          "ticket_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ticket Id"
          },
          "holder_user_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Holder User Id"
          },
          "scanned_at": {
            "type": "string",
            "format": "date-time",
            "title": "Scanned At"
          }
        },
        "type": "object",
        "required": [
          "allowed",
          "reason",
          "ticket_id",
          "holder_user_id",
          "scanned_at"
        ],
        "title": "EntryValidateResponse"
      },
      "ErrorDetail": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable explanation of the failure."
          },
          "field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Field"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ErrorDetail"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
