    "/v1/tickets/{ticket_id}/restore": {
      "post": {
        "tags": [
          "ticket-restore"
        ],
        "summary": "Restore a frozen ticket onto a re-enrolled device",
        "description": "Restores a frozen ticket to active use on a newly enrolled device.",
        "operationId": "restore_ticket_v1_tickets__ticket_id__restore_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "ticket_id",
            "in": "path",
            "required": true,
