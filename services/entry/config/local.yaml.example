# ── app ───────────────────────────────────────────────────────────────────────
debug: true
host: "127.0.0.1"
port: 8001
cors_origins:
  - "http://localhost:3000"
  - "http://localhost:5173"

# ── infrastructure ────────────────────────────────────────────────────────────
database_url: "postgresql+asyncpg://postgres:sekret@localhost:5432/qrew"
redis_url: "redis://localhost:6379/0"
nats_url: "nats://localhost:4222"

# ── security ──────────────────────────────────────────────────────────────────
internal_api_key: "dev-internal-secret"
ticketing_url: "http://localhost:8004"

# ── keys ──────────────────────────────────────────────────────────────────────
access_jwt_private_key: ""
access_jwt_previous_public_keys: ""
ticket_qr_jwt_private_key: ""
ticket_qr_jwt_previous_public_keys: ""
scanner_jwt_private_key: ""
scanner_jwt_public_key: ""
scanner_token_expire_hours: 12

# ── config ────────────────────────────────────────────────────────────────────
ticket_qr_audience: "qrew.scan"
entry_replay_grace_seconds: 10
entry_stats_cache_ttl_seconds: 5
entry_stats_default_window_hours: 24

# ── features ──────────────────────────────────────────────────────────────────
idempotency_enabled: true
idempotency_lock_seconds: 30
ratelimit_enabled: true

# ── observability ─────────────────────────────────────────────────────────────
otel_enabled: false
otel_endpoint: "http://localhost:4317"
